# LLM provider configuration (choose one provider)
LLM_PROVIDER=anthropic            # anthropic | openai
LLM_MODEL=claude-sonnet-4-6       # e.g. claude-sonnet-4-6, gpt-4.1
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Generation / orchestration
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_FALLBACK_MODEL=claude-haiku-4-5-20251001

# Storage
SQLITE_PATH=data/runtime/app.sqlite
VECTOR_DB=chroma                  # chroma | pgvector
CHROMA_PATH=.chroma

# App
API_PORT=8000
DASHBOARD_PORT=8501
