# LLM provider configuration
# Default is "mock" so the whole pipeline runs end-to-end with NO API key and zero cost.
# Switch to "gemini" (or add an openai/anthropic adapter) when you want real model calls.
LLM_PROVIDER=mock                 # mock | gemini
LLM_MODEL=gemini-2.0-flash        # used when LLM_PROVIDER=gemini
GOOGLE_API_KEY=

# Generation / orchestration resilience
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_FALLBACK_MODEL=               # optional cheaper model to fall back to (gemini provider only)

# Storage
SQLITE_PATH=data/runtime/app.sqlite
VECTOR_DB=chroma                  # chroma | pgvector (used from Day 3)
CHROMA_PATH=.chroma

# App
API_PORT=8000
DASHBOARD_PORT=8501
