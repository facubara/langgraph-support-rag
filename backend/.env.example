# LLM provider configuration
# Default is "mock" so the whole pipeline runs end-to-end with NO API key and zero cost.
# Switch to "gemini" (or add an openai/anthropic adapter) when you want real model calls.
LLM_PROVIDER=mock                 # mock | gemini
LLM_MODEL=gemini-2.0-flash        # used when LLM_PROVIDER=gemini
GOOGLE_API_KEY=

# Generation / orchestration resilience
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_FALLBACK_MODEL=               # optional cheaper model to fall back to (gemini provider only)

# Streaming / conversations
MOCK_STREAM_DELAY=0               # seconds between mock tokens; set >0 to visibly stream the demo
CONVERSATION_HISTORY_TURNS=6      # prior turns fed back into the response prompt

# Storage
SQLITE_PATH=data/runtime/app.sqlite
VECTOR_DB=chroma                  # chroma | pgvector (used from Day 3)
CHROMA_PATH=.chroma

# App
API_PORT=8000
DASHBOARD_PORT=8501

# CORS — origins allowed to call this API (the Next.js frontend). Comma-separated.
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_ORIGIN_REGEX=          # optional regex for Vercel preview URLs, e.g. https://.*-myproject\.vercel\.app
