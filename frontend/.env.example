# ---- FastAPI backend (server-side only; never exposed to the browser) ----
# Base URL of the FastAPI service. Local: http://localhost:8000  Prod: your Render URL.
BACKEND_URL=http://localhost:8000
# Shared secret the BFF attaches to backend calls. MUST match the backend's SERVICE_SHARED_SECRET.
SERVICE_SHARED_SECRET=dev-shared-secret-change-me

# ---- Auth.js (NextAuth v5) ----
# Generate with:  npx auth secret
AUTH_SECRET=
# Google OAuth credentials (https://console.cloud.google.com/apis/credentials).
# Authorized redirect URI: <site>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Set to true when running behind a proxy/host that Auth.js doesn't auto-detect (e.g. some PaaS).
# AUTH_TRUST_HOST=true

# ---- Public ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
